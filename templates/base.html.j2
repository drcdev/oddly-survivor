<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{% block title %}Oddly Survivor{% endblock %}</title>
<meta name="description" content="{% block description %}Spurious correlations in 50 seasons of US Survivor data.{% endblock %}">
<meta property="og:title" content="{% block og_title %}{{ self.title() }}{% endblock %}">
<meta property="og:description" content="{% block og_description %}{{ self.description() }}{% endblock %}">
<meta property="og:type" content="website">
{% block og_image %}{% endblock %}
<meta name="twitter:card" content="summary_large_image">
<link rel="stylesheet" href="{{ root }}style.css">
<link rel="icon" type="image/svg+xml" href="{{ root }}favicon.svg">
</head>
<body>
<header class="site-header">
  <a class="site-title" href="{{ root }}">Oddly Survivor</a>
  <nav class="site-nav">
    <a href="{{ root }}">Top</a>
    <a href="{{ root }}all/">All</a>
    <a href="{{ root }}about/">About</a>
  </nav>
</header>
<main>
{% block content %}{% endblock %}
</main>
<footer class="site-footer">
  <p>Data: <a href="https://github.com/doehm/survivoR">doehm/survivoR</a> (MIT) &middot; build {{ build_tag }}.
  Source: <a href="https://github.com/drcdev/oddly-survivor">drcdev/oddly-survivor</a>.</p>
  <p class="disclaimer">These correlations are presented for amusement. With ~1,400 candidate pairs and 50 seasons, many "significant" relationships are statistical coincidence, not causation. See <a href="{{ root }}about/">methodology</a>.</p>
</footer>
</body>
</html>
